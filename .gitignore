# Dependências do Node.js
node_modules/

# Ignorar todos os ficheiros dentro da pasta de perfis
public/assets/profiles/*


# Variáveis de Ambiente (MUITO IMPORTANTE PARA SEGURANÇA)
.env
.env.local
.env.development
.env.test
.env.production

# Logs de erro do NPM/Yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Arquivos de Sistema Operacional (Mac/Windows)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Uploads de Usuários (Ignora as fotos, mas mantém a pasta)
public/assets/profiles/*
!public/assets/profiles/.gitignore
!public/assets/profiles/.gitkeep

# Arquivos de IDE/Editores (VS Code, WebStorm, etc)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?